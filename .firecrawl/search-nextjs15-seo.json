  ```
  // pages/products/[slug].tsx
  import { useRouter } from 'next/router';
  
  export async function generateMetadata({ params }: Props): Promise<Metadata> {
    const { locale } = useRouter();
    const product = await getProduct(params.slug, locale);
  
    return {
      title: product.localizedTitle[locale],
      description: product.localizedDescription[locale],
      alternates: {
        canonical: `https://yourstore.com/${locale}/products/${params.slug}`,
        languages: {
          'en': `https://yourstore.com/en/products/${params.slug}`,
          'es': `https://yourstore.es/products/${params.slug}`,
          'fr': `https://yourstore.com/fr/products/${params.slug}`,
        },
      },
    };
  }
