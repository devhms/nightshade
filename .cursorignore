# --- AI Context Protection (Deny List) ---
# This file prevents Cursor/Claude from reading or indexing files
# into its context window, protecting local secrets or massive binary files.

# Ignore compiled output
target/
_nightshade_output/
*.class
*.jar

# Ignore secrets (AI should never read your private keys)
.env
*.pem
*.key

# Ignore enormous generated datasets that will blow up the context window
docs/superpowers/
logs/
